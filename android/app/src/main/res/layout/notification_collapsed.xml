<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp">

    <!-- Status Indicator Icon Container (Rounded Badge) -->
    <FrameLayout
        android:id="@+id/notification_status_icon_container"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_centerVertical="true"
        android:background="@drawable/widget_btn_bg"
        android:padding="8dp">

        <ImageView
            android:id="@+id/notification_status_icon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_timer"
            android:contentDescription="Status Icon" />
    </FrameLayout>

    <!-- Status Details -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_toEndOf="@id/notification_status_icon_container"
        android:layout_marginStart="14dp"
        android:layout_centerVertical="true">

        <TextView
            android:id="@+id/notification_status_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FASTING"
            android:textColor="@color/widget_text_primary"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/notification_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="36m remaining"
            android:textColor="@color/widget_text_secondary"
            android:textSize="10sp"
            android:fontFamily="sans-serif"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Large Timer Display on Right -->
    <TextView
        android:id="@+id/notification_large_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:textColor="@color/widget_text_primary"
        android:textSize="18sp"
        android:fontFamily="monospace"
        android:textStyle="bold" />

    <!-- Tiny Progress Bar at the absolute bottom -->
    <ProgressBar
        android:id="@+id/notification_progress_bar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_alignParentBottom="true"
        android:max="100"
        android:progress="0" />
</RelativeLayout>
