<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@drawable/widget_bg">

    <!-- Progress Ring & Center Content -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true">

        <!-- Custom Draw Circular Progress Ring -->
        <ImageView
            android:id="@+id/widget_progress_ring"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:layout_centerInParent="true" />

        <!-- Centered Timer Content -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_centerInParent="true">

            <TextView
                android:id="@+id/widget_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FASTING"
                android:textColor="@color/widget_text_secondary"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_countdown_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15:34:12"
                android:textColor="@color/widget_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/widget_percent_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="74%"
                android:textColor="@color/widget_text_secondary"
                android:textSize="9sp" />
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>
