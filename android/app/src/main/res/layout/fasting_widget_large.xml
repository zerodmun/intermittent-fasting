<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_bg">

    <!-- Top Section: Header & Gauge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.5"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Progress ring left -->
        <RelativeLayout
            android:layout_width="80dp"
            android:layout_height="80dp">

            <ImageView
                android:id="@+id/widget_progress_ring"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/widget_percent_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="74%"
                android:textColor="@color/widget_text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_centerInParent="true" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/widget_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FASTING"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_countdown_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15h 34m remaining"
                android:textColor="@color/widget_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/widget_streak_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 5 Days Streak"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/widget_divider"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp" />

    <!-- Middle Section: Stats & Body Composition -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.8"
        android:orientation="vertical"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Body Summary"
            android:textColor="@color/widget_text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Weight card -->
            <LinearLayout
                android:id="@+id/widget_weight_layout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/widget_card_bg"
                android:orientation="vertical"
                android:padding="10dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Weight"
                    android:textColor="@color/widget_text_secondary"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_weight_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="78.4 kg"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Body fat card -->
            <LinearLayout
                android:id="@+id/widget_body_fat_layout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:background="@drawable/widget_card_bg"
                android:orientation="vertical"
                android:padding="10dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Body Fat"
                    android:textColor="@color/widget_text_secondary"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_body_fat_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="16.2% (Fitness)"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/widget_transition_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next transition: Eating window starts at 09:00"
            android:textColor="@color/widget_text_secondary"
            android:textSize="10sp"
            android:layout_marginTop="12dp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/widget_divider"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp" />

    <!-- Bottom Section: Quick Actions Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/widget_btn_open_app"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/widget_btn_bg"
            android:gravity="center"
            android:text="Open App"
            android:textColor="@color/widget_text_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginEnd="4dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/widget_btn_edit_schedule"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/widget_btn_bg"
            android:gravity="center"
            android:text="Edit Plan"
            android:textColor="@color/widget_text_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/widget_btn_log_weight"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/widget_btn_bg"
            android:gravity="center"
            android:text="Log Weight"
            android:textColor="@color/widget_text_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>
</LinearLayout>
